{
  "permissions": {
    "allow": [
      "Bash(uv sync:*)",
      "Bash(uv run nox:*)",
      "Bash(uv run --only-group=nox nox:*)",
      "Bash(TC_HOST=localhost TESTCONTAINERS_RYUK_DISABLED=true uv run --only-group=nox nox:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "WebFetch(domain:*.lsst.io)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/deny-bare-python.sh\""
          }
        ]
      }
    ]
  }
}
