{
  "name": "docverse",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    // Node 22+ for the Cloudflare worker (cloudflare-worker/package.json
    // requires "node": ">=22").
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    // Docker-in-Docker for the testcontainers-based Postgres tests.
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  // DinD requires the container to START as root: the docker-in-docker
  // Feature's docker-init.sh runs as PID 1 and only starts dockerd cleanly
  // when it is root, and --privileged lets dockerd manage iptables/cgroups.
  // remoteUser stays "vscode" so lifecycle/agent commands run unprivileged.
  // Drop containerUser and the sandbox dies on startup with
  // "Shell server terminated (code: 126)" / "no users found".
  // Stoker's derive carries containerUser/privileged into its AFK sandbox.
  "containerUser": "root",
  "remoteUser": "vscode",
  "privileged": true,
  "postCreateCommand": "uv sync",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "charliermarsh.ruff"]
    }
  }
}
